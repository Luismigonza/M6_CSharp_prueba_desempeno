@model RentaSegura.Web.Models.ProfileViewModel
@{
    ViewData["Title"] = "Mi perfil";
    Layout = "_Layout";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <h4 class="fw-bold mb-4"><i class="bi bi-person-circle me-2 text-warning"></i>Mi perfil</h4>

        <div class="row g-4">
            <!-- Cambiar nombre -->
            <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <h6 class="fw-semibold mb-3">Información personal</h6>
                        <form asp-action="UpdateName" method="post">
                            @Html.AntiForgeryToken()
                            <div class="mb-3">
                                <label asp-for="FullName" class="form-label">Nombre completo</label>
                                <input asp-for="FullName" class="form-control" />
                                <span asp-validation-for="FullName" class="text-danger small"></span>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Correo electrónico</label>
                                <input class="form-control" value="@User.Identity?.Name" disabled />
                                <div class="form-text" style="font-size:.75rem;">El correo no puede cambiarse.</div>
                            </div>
                            <button type="submit" class="btn btn-warning fw-semibold w-100">
                                Guardar nombre
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Cambiar contraseña -->
            <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <h6 class="fw-semibold mb-3">Cambiar contraseña</h6>
                        <form asp-action="ChangePassword" method="post">
                            @Html.AntiForgeryToken()
                            <div class="mb-3">
                                <label class="form-label">Contraseña actual</label>
                                <input name="CurrentPassword" type="password" class="form-control"
                                       placeholder="••••••••" autocomplete="current-password" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Nueva contraseña</label>
                                <input name="NewPassword" type="password" class="form-control"
                                       placeholder="Mín. 8 caracteres" autocomplete="new-password" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Confirmar nueva contraseña</label>
                                <input name="ConfirmPassword" type="password" class="form-control"
                                       placeholder="••••••••" autocomplete="new-password" />
                            </div>
                            <button type="submit" class="btn btn-outline-dark fw-semibold w-100">
                                Cambiar contraseña
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
