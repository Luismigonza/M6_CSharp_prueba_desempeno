@using System.Text.Json
@model RentaSegura.Web.Services.DashboardMetrics
@{
    ViewData["Title"] = "Dashboard";
    var from = (DateOnly)ViewBag.From;
    var to = (DateOnly)ViewBag.To;
    var labels = Model.RevenueByMonth.Select(m => m.Month).ToList();
    var data = Model.RevenueByMonth.Select(m => m.Revenue).ToList();
    var occupancyPct = Math.Round(Model.OccupancyRate * 100, 1);
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
    <h1 class="h4 mb-0"><i class="bi bi-graph-up-arrow"></i> Dashboard de rendimiento</h1>
    <a class="btn btn-success" asp-action="Export"><i class="bi bi-file-earmark-excel"></i> Exportar portafolio (Excel)</a>
</div>

<form method="get" asp-action="Index" class="row g-2 align-items-end mb-4">
    <div class="col-auto">
        <label class="form-label small">Desde</label>
        <input type="date" name="from" value="@from.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
    </div>
    <div class="col-auto">
        <label class="form-label small">Hasta</label>
        <input type="date" name="to" value="@to.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
    </div>
    <div class="col-auto">
        <button class="btn btn-sm btn-dark">Aplicar</button>
    </div>
</form>

<!-- KPIs -->
<div class="row g-3 mb-4">
    <div class="col-md-3 col-6">
        <div class="card border-0 shadow-sm h-100"><div class="card-body">
            <div class="text-muted small">Ingresos</div>
            <div class="h4 mb-0 text-success">@Model.TotalRevenue.ToString("C0")</div>
        </div></div>
    </div>
    <div class="col-md-3 col-6">
        <div class="card border-0 shadow-sm h-100"><div class="card-body">
            <div class="text-muted small">Reservas</div>
            <div class="h4 mb-0">@Model.ReservationCount</div>
        </div></div>
    </div>
    <div class="col-md-3 col-6">
        <div class="card border-0 shadow-sm h-100"><div class="card-body">
            <div class="text-muted small">Noches reservadas</div>
            <div class="h4 mb-0">@Model.BookedNights</div>
        </div></div>
    </div>
    <div class="col-md-3 col-6">
        <div class="card border-0 shadow-sm h-100"><div class="card-body">
            <div class="text-muted small">Ocupación</div>
            <div class="h4 mb-0">@occupancyPct%</div>
            <div class="progress mt-1" style="height:6px;">
                <div class="progress-bar bg-warning" style="width:@occupancyPct%"></div>
            </div>
        </div></div>
    </div>
</div>

<!-- Gráfica de ingresos por mes -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <h6 class="text-muted mb-3">Ingresos por mes</h6>
        @if (data.Count == 0)
        {
            <p class="text-muted small mb-0">Sin datos en el periodo seleccionado.</p>
        }
        else
        {
            <canvas id="revenueChart" height="90"></canvas>
        }
    </div>
</div>

<!-- Desglose por inmueble -->
<div class="card border-0 shadow-sm">
    <div class="card-body">
        <h6 class="text-muted mb-3">Rendimiento por inmueble</h6>
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr><th>Inmueble</th><th>Reservas</th><th>Noches</th><th>Ingresos</th><th></th></tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.ByProperty)
                    {
                        <tr>
                            <td class="fw-semibold">@p.Title</td>
                            <td>@p.Reservations</td>
                            <td>@p.BookedNights</td>
                            <td class="text-success">@p.Revenue.ToString("C0")</td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-success" asp-action="Export" asp-route-propertyId="@p.PropertyId">
                                    <i class="bi bi-file-earmark-excel"></i> Excel
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    @if (data.Count > 0)
    {
        <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
        <script>
            const ctx = document.getElementById('revenueChart');
            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: @Html.Raw(JsonSerializer.Serialize(labels)),
                    datasets: [{
                        label: 'Ingresos (COP)',
                        data: @Html.Raw(JsonSerializer.Serialize(data)),
                        backgroundColor: '#f59e0b'
                    }]
                },
                options: {
                    plugins: { legend: { display: false } },
                    scales: { y: { beginAtZero: true } }
                }
            });
        </script>
    }
}
