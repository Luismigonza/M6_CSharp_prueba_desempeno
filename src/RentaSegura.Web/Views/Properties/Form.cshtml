@model PropertyFormViewModel
@{
    var isEdit = Model.Id is not null;
    ViewData["Title"] = isEdit ? "Editar inmueble" : "Publicar inmueble";
    var action = isEdit ? "Edit" : "Create";
}
<div class="row justify-content-center">
    <div class="col-md-8">
        <h1 class="h4 mb-3">@ViewData["Title"]</h1>

        <div asp-validation-summary="All" class="text-danger small mb-2"></div>

        <form asp-action="@action" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="Title" class="form-label">Título</label>
                        <input asp-for="Title" class="form-control" placeholder="Ej. Apartamento con vista al Poblado" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Descripción</label>
                        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="City" class="form-label">Ciudad</label>
                            <input asp-for="City" class="form-control" placeholder="Medellín" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Address" class="form-label">Dirección</label>
                            <input asp-for="Address" class="form-control" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="PricePerNight" class="form-label">Tarifa por noche (COP)</label>
                            <input asp-for="PricePerNight" class="form-control" type="number" step="1000" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="Bedrooms" class="form-label">Habitaciones</label>
                            <input asp-for="Bedrooms" class="form-control" type="number" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="Capacity" class="form-label">Capacidad (huéspedes)</label>
                            <input asp-for="Capacity" class="form-control" type="number" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ImageUrl" class="form-label">URL de la foto</label>
                        <input asp-for="ImageUrl" class="form-control" placeholder="https://..." />
                        <div class="form-text">Para el MVP usamos una URL de imagen.</div>
                    </div>
                    <div class="form-check mb-3">
                        <input asp-for="IsPublished" class="form-check-input" />
                        <label asp-for="IsPublished" class="form-check-label">Publicado (visible en el catálogo)</label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning fw-semibold">@(isEdit ? "Guardar cambios" : "Publicar")</button>
                        <a class="btn btn-outline-secondary" asp-action="Index">Cancelar</a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>
