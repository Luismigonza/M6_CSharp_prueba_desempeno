@model CatalogViewModel
@{
    ViewData["Title"] = "Explorar inmuebles";
    var hasFilter = !string.IsNullOrWhiteSpace(Model.City);
}

<!-- Hero con buscador solo por ciudad -->
<div class="hero-search mb-4">
    <h1 class="h4 fw-bold text-white mb-1">Encuentra tu próxima estancia</h1>
    <p class="text-white opacity-75 mb-3" style="font-size:.88rem;">
        Explora sin cuenta. Solo necesitas una cuando reserves o guardes favoritos.
    </p>
    <form method="get" asp-action="Index" class="d-flex align-items-center gap-2 flex-wrap">
        <div class="search-pill">
            <i class="bi bi-search text-white opacity-50" style="font-size:.85rem;"></i>
            <input name="city" value="@Model.City" placeholder="¿A dónde vas?" autocomplete="off" />
            @if (hasFilter)
            {
                <a href="/" class="btn-clear" title="Borrar filtro"><i class="bi bi-x"></i></a>
            }
            <button type="submit" class="btn-search">Buscar</button>
        </div>
        @if (hasFilter)
        {
            <span class="badge text-white opacity-75" style="background:rgba(255,255,255,.15);">
                @Model.Properties.Count resultado(s) para "@Model.City"
            </span>
        }
    </form>
</div>

@if (Model.Properties.Count == 0)
{
    <div class="text-center py-5">
        <h5 class="fw-semibold">Sin resultados para "@Model.City"</h5>
        <p class="text-muted small">Prueba con otra ciudad o <a href="/">ve todos los inmuebles</a>.</p>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var p in Model.Properties)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card prop-card h-100">
                    <div class="img-wrap position-relative">
                        <img src="@(p.ImageUrl ?? "https://images.unsplash.com/photo-1502672260266-1c1ef2d93688?w=800")"
                             class="card-img-top" alt="@p.Title" />
                        @if (User.Identity?.IsAuthenticated == true && !User.IsInRole(Roles.Anfitrion))
                        {
                            <button class="btn-fav position-absolute top-0 end-0 m-2"
                                    data-id="@p.Id" title="Favorito">
                                <i class="bi @(Model.FavoriteIds.Contains(p.Id) ? "bi-heart-fill text-danger" : "bi-heart text-dark")"></i>
                            </button>
                        }
                    </div>
                    <div class="card-body d-flex flex-column">
                        <p class="text-muted mb-1" style="font-size:.75rem;">
                            <i class="bi bi-geo-alt-fill me-1" style="color:var(--rs-amber);"></i>@p.City
                        </p>
                        <h6 class="fw-semibold mb-1">@p.Title</h6>
                        <p class="text-muted small flex-grow-1" style="font-size:.8rem;
                            overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;">
                            @p.Description
                        </p>
                        <div class="d-flex justify-content-between align-items-center mt-2">
                            <span class="price-tag">
                                @p.PricePerNight.ToString("C0") <small>/ noche</small>
                            </span>
                            <a class="btn btn-sm btn-warning px-3"
                               asp-action="Details" asp-route-id="@p.Id">Ver</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
