@model RegisterViewModel
@{
    ViewData["Title"] = "Crear cuenta";
    Layout = "_Layout";
}

<div class="auth-card">
    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <div class="text-center mb-4">
                <span style="font-size:2rem;"></span>
                <h4 class="fw-bold mt-2 mb-0">Crear cuenta</h4>
                <p class="text-muted small">Únete a RentaSegura gratis</p>
            </div>

            @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
            {
                <div asp-validation-summary="All" class="alert alert-danger py-2 small mb-3"></div>
            }

            <form asp-action="Register" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ReturnUrl" />

                <div class="mb-3">
                    <label asp-for="FullName" class="form-label">Nombre completo</label>
                    <input asp-for="FullName" class="form-control" placeholder="Tu nombre" />
                </div>
                <div class="mb-3">
                    <label asp-for="Email" class="form-label">Correo electrónico</label>
                    <input asp-for="Email" class="form-control" placeholder="tu@correo.com" autocomplete="username" />
                </div>
                <div class="mb-3">
                    <label asp-for="Password" class="form-label">Contraseña</label>
                    <input asp-for="Password" class="form-control" placeholder="Mín. 8 caracteres" autocomplete="new-password" />
                    <div class="form-text" style="font-size:.75rem;">
                        Debe incluir mayúscula, número y símbolo.
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label">Quiero unirme como</label>
                    <div class="row g-2">
                        <div class="col-6">
                            <input type="radio" class="btn-check" name="Role" value="Huesped" id="rHuesped" checked />
                            <label class="btn btn-outline-dark w-100" for="rHuesped">
                                 Huésped
                            </label>
                        </div>
                        <div class="col-6">
                            <input type="radio" class="btn-check" name="Role" value="Anfitrion" id="rAnfitrion" />
                            <label class="btn btn-outline-dark w-100" for="rAnfitrion">
                                 Anfitrión
                            </label>
                        </div>
                    </div>
                </div>

                <button type="submit" class="btn btn-warning w-100 fw-semibold py-2">
                    Crear cuenta
                </button>
            </form>

            <hr class="my-3" />
            <p class="text-center small mb-1 text-muted">¿Ya tienes cuenta?</p>
            <a class="btn btn-outline-dark w-100"
               asp-action="Login" asp-route-returnUrl="@Model.ReturnUrl">
                Iniciar sesión
            </a>
        </div>
    </div>
</div>
